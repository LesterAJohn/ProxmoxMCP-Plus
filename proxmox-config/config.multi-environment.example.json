{
    "default_environment": "production",
    "runtime_config_reload": true,
    "logging": {
        "level": "INFO"
    },
    "mcp": {
        "host": "127.0.0.1",
        "port": 8000,
        "transport": "STDIO"
    },
    "security": {
        "dev_mode": false
    },
    "jobs": {
        "sqlite_path": "proxmox-jobs.sqlite3"
    },
    "command_policy": {
        "mode": "deny_all",
        "allow_patterns": [],
        "high_risk_mode": "audit_only",
        "high_risk_require_approval_token": false
    },
    "environments": {
        "production": {
            "proxmox": {
                "host": "pve-prod.example.internal",
                "port": 8006,
                "verify_ssl": true,
                "service": "PVE"
            },
            "auth": {
                "user": "automation@pve",
                "token_name": "mcp-token",
                "token_value": "replace-with-prod-token"
            },
            "ssh": {
                "user": "mcp-agent",
                "port": 22,
                "key_file": "~/.ssh/proxmox_prod_key",
                "use_sudo": true,
                "host_overrides": {
                    "pve-prod-1": "pve-prod-1.example.internal"
                },
                "strict_host_key_checking": true,
                "prefer_ssh_client": false
            }
        },
        "lab": {
            "proxmox": {
                "host": "pve-lab.example.internal",
                "port": 8006,
                "verify_ssl": true,
                "service": "PVE"
            },
            "auth": {
                "user": "automation@pve",
                "token_name": "mcp-token",
                "token_value": "replace-with-lab-token"
            },
            "ssh": {
                "user": "mcp-agent",
                "port": 22,
                "key_file": "~/.ssh/proxmox_lab_key",
                "host_overrides": {
                    "pve-lab-1": "pve-lab-1.example.internal"
                },
                "strict_host_key_checking": true,
                "prefer_ssh_client": false
            },
            "jobs": {
                "sqlite_path": "proxmox-jobs-lab.sqlite3"
            }
        }
    }
}
